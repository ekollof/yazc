# All other misc crap goes here.

# Preferred editor for local and remote sessions
export EDITOR=nvim

# Keep unique PATH entries (mirror of zshrc — catches everything added below)
typeset -U path PATH

# PATH additions — use array form so typeset -U deduplicates automatically
path=(
  ~/bin
  ~/.config/emacs/bin
  ~/.local/bin
  ~/.cargo/bin
  ~/node_modules/.bin
  $GOPATH/bin
  /home/ekollof/.opencode/bin  # kept here for clarity; .zshrc also adds it
  $path
)

# Go
export GOPATH=$HOME/go

# Gem
if command -v ruby > /dev/null 2>&1; then
  GEM_USER_DIR=$(ruby -e 'puts Gem.user_dir' 2>/dev/null)
  [[ -n "$GEM_USER_DIR" ]] && path+=("$GEM_USER_DIR/bin")
fi

if [[ -e ~/bin/aliases.sh ]]; then
  source ~/bin/aliases.sh
fi

if [[ -n "$KITTY_WINDOW_ID" ]]; then
  # Load kitty shell integration (marks, OSC title, cursor shape, etc.)
  # KITTY_INSTALLATION_DIR is set by kitty in the environment
  if [[ -n "$KITTY_INSTALLATION_DIR" ]]; then
    autoload -Uz -- "$KITTY_INSTALLATION_DIR/shell-integration/zsh/kitty-integration"
    kitty-integration
    unfunction kitty-integration
  fi

  # Use the kitten SSH wrapper so terminfo and features carry over to remote hosts
  alias ssh='kitten ssh'

  # Side-by-side diff with syntax highlighting
  alias diff='kitten diff'

  # Clipboard access (works locally and over SSH via kitten)
  alias pbcopy='kitten clipboard'
  alias pbpaste='kitten clipboard --get-clipboard'

  # Hyperlinked ripgrep — file paths in output become clickable OSC 8 links
  if command -v rg > /dev/null 2>&1; then
    alias rg='kitten hyperlinked_grep'
  fi
fi

reload_gtk() {
  local theme
  theme=$(gsettings get org.gnome.desktop.interface gtk-theme)
  gsettings set org.gnome.desktop.interface gtk-theme ''
  sleep 1
  gsettings set org.gnome.desktop.interface gtk-theme "$theme"
}

alias config='git --git-dir=$HOME/.cfg/ --work-tree=$HOME'

# KVM
export VIRSH_DEFAULT_CONNECT_URI=qemu:///system
export LIBVIRT_DEFAULT_URI=qemu:///system

# xterm transparency
if [[ -v XTERM_VERSION ]]; then
  if command -v transset-df > /dev/null 2>&1; then
    transset-df --id "$WINDOWID" 0.75 > /dev/null
  elif command -v transset > /dev/null 2>&1; then
    transset --id "$WINDOWID" 0.75 > /dev/null
  fi
fi

# Apply wallust colour theme (local sessions only, skip over SSH)
if [[ ! -e ~/.noauto && -z "$SSH_TTY" ]]; then
  if command -v wallust > /dev/null 2>&1 && [[ -f ~/.wallpaper ]]; then
    () {
      local _wseq="${XDG_CACHE_HOME:-$HOME/.cache}/wallust/sequences"
      local _wstamp="${XDG_CACHE_HOME:-$HOME/.cache}/wallust/applied.stamp"
      command mkdir -p "${_wstamp:h}"
      # Re-generate theme only when wallpaper changes
      if [[ ! -f $_wstamp || ~/.wallpaper -nt $_wstamp ]]; then
        (wallust run -u -q "$(<~/.wallpaper)" && touch "$_wstamp" &)
      fi
      # Always replay colour sequences into every new terminal window
      [[ -f $_wseq ]] && command cat "$_wseq"
    }
  fi
fi

# fortune — interactive shells only, skip over SSH to avoid cluttering scp/rsync
if [[ -o interactive && -z "$SSH_TTY" ]]; then
  command -v fortune > /dev/null 2>&1 && fortune -o
fi

case $TERM in
  (*xterm* | rxvt | rxvt-unicode-256color)
    # Skip for kitty: shell integration handles titles via OSC natively
    if [[ -z "$KITTY_WINDOW_ID" ]]; then
      function precmd { print -Pn "\e]0;%(1j,%j job%(2j|s|); ,)%~\a" }
      function preexec { printf "\033]0;%s\a" "$1" }
    fi
  ;;
esac

# Conditionally load mise (must load before carapace so tools are in PATH)
# Cache the init script — regenerate only when the mise binary changes.
if command -v mise > /dev/null 2>&1; then
  () {
    local _cache="${XDG_CACHE_HOME:-$HOME/.cache}/mise/init.zsh"
    local _bin="${commands[mise]}"
    command mkdir -p "${_cache:h}"
    if [[ ! -f $_cache || $_bin -nt $_cache ]]; then
      mise activate zsh >| "$_cache" 2>/dev/null
    fi
    source "$_cache"
  }
fi

# Conditionally load carapace (after mise so it can find mise-installed tools)
# Use a cached completion script — regenerate only when carapace binary changes
if command -v carapace > /dev/null 2>&1; then
  () {
    local _carapace_cache="${XDG_CACHE_HOME:-$HOME/.cache}/carapace/init.zsh"
    local _carapace_bin="${commands[carapace]}"
    command mkdir -p "${_carapace_cache:h}"
    if [[ ! -f $_carapace_cache || $_carapace_bin -nt $_carapace_cache ]]; then
      carapace _carapace zsh >| "$_carapace_cache" 2>/dev/null
    fi
    source "$_carapace_cache"
  }
fi

# Conditionally load starship (overrides custom prompt from zsh-prompt)
# Skip starship on terminals that lack 256-color or truecolor support.
# Cache the init script — regenerate only when the starship binary changes.
_term_has_starship_support() {
  case "$TERM" in
    dtterm|cde*|dumb|vt[0-9]*) return 1 ;;
  esac
  local ncolors
  ncolors=$(tput colors 2>/dev/null) || return 1
  (( ncolors >= 256 )) || return 1
  [[ "$COLORTERM" == (truecolor|24bit) ]] || return 1
  return 0
}

if command -v starship > /dev/null 2>&1 && _term_has_starship_support; then
  () {
    local _cache="${XDG_CACHE_HOME:-$HOME/.cache}/starship/init.zsh"
    local _bin="${commands[starship]}"
    command mkdir -p "${_cache:h}"
    if [[ ! -f $_cache || $_bin -nt $_cache ]]; then
      starship init zsh >| "$_cache" 2>/dev/null
    fi
    source "$_cache"
  }
  # starship manages the prompt — remove the vcs_info precmd hook that
  # zsh-prompt registered so it doesn't run a git process on every prompt
  # for no visible benefit.
  precmd_functions=("${(@)precmd_functions:#precmd_vcs_info}")
fi
unfunction _term_has_starship_support

# Conditionally load zoxide (smarter cd)
# Cache the init script — regenerate only when the zoxide binary changes.
if command -v zoxide > /dev/null 2>&1; then
  () {
    local _cache="${XDG_CACHE_HOME:-$HOME/.cache}/zoxide/init.zsh"
    local _bin="${commands[zoxide]}"
    command mkdir -p "${_cache:h}"
    if [[ ! -f $_cache || $_bin -nt $_cache ]]; then
      zoxide init zsh >| "$_cache" 2>/dev/null
    fi
    source "$_cache"
  }
fi

if command -v keychain > /dev/null 2>&1; then
  # Use kwallet-askpass wrapper: retrieves/stores passphrases via kwalletcli
  # (which works without a parent window), falling back to ksshaskpass for
  # the actual prompt. ksshaskpass alone can't store to KWallet when invoked
  # from ssh-add/keychain because it has no window handle.
  export SSH_ASKPASS="$HOME/bin/kwallet-askpass"
  export SSH_ASKPASS_REQUIRE=prefer

  # Find all SSH private keys (exclude .pub, known_hosts, config, etc.)
  local -a SSH_KEYS=()
  for key in "$HOME"/.ssh/id_*; do
    [[ -f "$key" && "$key" != *.pub ]] && SSH_KEYS+=("$key")
  done

  [[ ${#SSH_KEYS[@]} -gt 0 ]] && keychain --ssh-allow-gpg -q "${SSH_KEYS[@]}"
fi

if [[ -e "$HOME/.keychain/$HOST-sh" ]]; then
  source "$HOME/.keychain/$HOST-sh"
  # Propagate keychain's SSH_AUTH_SOCK into the systemd user environment and
  # dbus activation environment so all subsequently launched processes
  # (including those not started from this shell) use the correct agent socket.
  if [[ -n "$SSH_AUTH_SOCK" ]] && command -v systemctl > /dev/null 2>&1; then
    systemctl --user set-environment SSH_AUTH_SOCK="$SSH_AUTH_SOCK"
  fi
  if [[ -n "$SSH_AUTH_SOCK" ]] && command -v dbus-update-activation-environment > /dev/null 2>&1; then
    dbus-update-activation-environment SSH_AUTH_SOCK="$SSH_AUTH_SOCK"
  fi
fi
